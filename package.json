{
  "name": "cherry-bounty-radar",
  "version": "0.1.0",
  "description": "CLI radar for finding real, low-risk GitHub bounty issues and generating attempt/claim templates.",
  "type": "module",
  "bin": {
    "cherry-bounty": "dist/cli.js",
    "cherry-bounty-radar": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
